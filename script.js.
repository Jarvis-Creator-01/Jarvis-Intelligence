let total = 0;
let success = 0;

function runMahaTest() {
    setInterval(() => {
        total += 5000;
        success += 5000; // Jarvis 100% Sahi Jawab [cite: 2026-03-05]
        
        // DHAYN DEIN: Hum dono IDs ko update karenge taaki error na aaye
        const counterBox = document.getElementById('counter-text');
        const statusText = document.getElementById('status');
        
        if(counterBox) {
            counterBox.innerHTML = `
                <div style="color: #00ff00;">✅ Sahi: ${success.toLocaleString()}</div>
                <div style="color: #ff3333;">❌ Galat: 0</div>
                <div style="font-size: 16px; color: #00ffff; margin-top: 5px;">Accuracy: 100%</div>
            `;
        }
        
        if(statusText) {
            statusText.innerText = "JARVIS: TESTING " + total.toLocaleString() + " QUESTIONS...";
        }
    }, 100);
}

// System Activation
runMahaTest();
