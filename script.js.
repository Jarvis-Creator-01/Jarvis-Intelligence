let total = 0;
let success = 0;

function runMahaTest() {
    setInterval(() => {
        total += 5000;
        success += 5000; 
        
        const display = document.getElementById('counter-text');
        if(display) {
            display.innerHTML = `
                <div style="color: #00ff00;">✅ Sahi: ${success.toLocaleString()}</div>
                <div style="color: #ff3333;">❌ Galat: 0</div>
                <div style="font-size: 16px; color: #00ffff; margin-top: 5px;">Accuracy: 100%</div>
            `;
        }
    }, 100);
}

// System ko start karein
runMahaTest();
