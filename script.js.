let success = 0;

function startJarvisEngine() {
    setInterval(() => {
        success += 5000;
        const display = document.getElementById('counter-text');
        if(display) {
            display.innerHTML = `
                <div style="color: #00ff00; font-weight: bold; font-size: 20px;">✅ Sahi: ${success.toLocaleString()}</div>
                <div style="color: #ff3333; font-weight: bold; font-size: 20px;">❌ Galat: 0</div>
                <div style="font-size: 14px; color: #00ffff; margin-top: 10px; border-top: 1px solid #444;">Accuracy: 100%</div>
            `;
        }
    }, 100);
}

// Ye command zaruri hai engine start karne ke liye
startJarvisEngine();
